<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>MOVE · Sistema operativo idworld</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
:root{--ink-0:#0a0a0b;--ink-1:#121214;--ink-2:#1a1a1d;--ink-3:#27272a;--ink-4:#3f3f46;--ash-1:#71717a;--ash-2:#a1a1aa;--ash-3:#d4d4d8;--paper:#f4f4f5;--cyan-1:#22d3ee;--cyan-2:#06b6d4;--cyan-3:#0891b2;--cyan-deep:#083344;--warm:#f59e0b;--hot:#ef4444;--ok:#22c55e;--purple:#a78bfa;--coral:#fb7185;--fs:'Archivo',system-ui,sans-serif;--fm:'JetBrains Mono',ui-monospace,monospace}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--ink-0);color:var(--ash-3);font-family:var(--fs);line-height:1.5;-webkit-font-smoothing:antialiased;overflow-x:hidden}
button{font:inherit;color:inherit;background:none;border:none;cursor:pointer}
.hide{display:none!important}

/* ═══ HOME (selector rol) ═══ */
.home{min-height:100vh;display:flex;flex-direction:column;padding:40px;background:radial-gradient(ellipse 1200px 800px at 50% 0%,rgba(8,145,178,0.12),transparent 60%)}
.home-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:80px}
.logo-mini{display:flex;align-items:baseline;gap:12px;font-family:var(--fm);font-size:11px;text-transform:uppercase;letter-spacing:.1em}
.logo-mini strong{font-family:var(--fs);font-weight:900;font-size:22px;color:var(--paper);letter-spacing:-.02em}
.logo-mini span{color:var(--ash-1)}
.home-meta{font-family:var(--fm);font-size:10px;color:var(--ash-1);letter-spacing:.1em;text-transform:uppercase}
.home-meta::before{content:'●';color:var(--ok);margin-right:6px;animation:pulse 2.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

.home-hero{max-width:1200px;margin:0 auto 80px;text-align:center;width:100%}
.home-kicker{font-family:var(--fm);font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--cyan-1);margin-bottom:20px}
.home-title{font-weight:800;font-size:clamp(36px,5vw,64px);letter-spacing:-.03em;line-height:1.05;color:var(--paper);margin-bottom:24px}
.home-title em{font-style:normal;color:var(--cyan-1)}
.home-sub{font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:300;font-size:20px;color:var(--ash-2);max-width:600px;margin:0 auto}

.roles{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:24px;width:100%}
.role-card{background:var(--ink-1);border:1px solid var(--ink-3);padding:40px 32px;transition:all .3s;cursor:pointer;position:relative;overflow:hidden;text-align:left}
.role-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--cc,var(--cyan-2));transform:scaleY(0);transform-origin:top;transition:transform .3s}
.role-card:hover{border-color:var(--cc,var(--cyan-2));transform:translateY(-4px)}
.role-card:hover::before{transform:scaleY(1)}
.role-card .ic{width:48px;height:48px;border:1px solid var(--cc,var(--cyan-2));display:flex;align-items:center;justify-content:center;margin-bottom:28px;color:var(--cc,var(--cyan-2))}
.role-card h3{font-weight:700;font-size:24px;letter-spacing:-.015em;color:var(--paper);margin-bottom:8px}
.role-card .subt{font-family:var(--fm);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--ash-1);margin-bottom:24px}
.role-card p{font-size:15px;color:var(--ash-2);line-height:1.6;margin-bottom:28px}
.role-card ul{list-style:none;font-family:var(--fm);font-size:11.5px;color:var(--ash-1);border-top:1px solid var(--ink-3);padding-top:20px}
.role-card li{padding:6px 0;display:flex;justify-content:space-between;gap:12px}
.role-card li strong{color:var(--cc,var(--cyan-1));font-weight:500}
.role-card .enter{margin-top:28px;font-family:var(--fm);font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--cc,var(--cyan-2));padding:14px 20px;border:1px solid var(--cc,var(--cyan-2));display:inline-block;transition:background .2s}
.role-card:hover .enter{background:var(--cc,var(--cyan-2));color:var(--ink-0)}

/* ═══ APP SHELL ═══ */
.app{min-height:100vh;display:grid;grid-template-rows:56px 1fr;grid-template-columns:240px 1fr;grid-template-areas:"nav hdr""nav main"}
.appnav{grid-area:nav;background:var(--ink-1);border-right:1px solid var(--ink-3);padding:20px 0;display:flex;flex-direction:column}
.appnav .brand{padding:0 24px 24px;border-bottom:1px solid var(--ink-3);margin-bottom:20px}
.appnav .brand strong{font-weight:900;font-size:18px;color:var(--paper);letter-spacing:-.02em;display:block}
.appnav .brand span{font-family:var(--fm);font-size:10px;color:var(--ash-1);text-transform:uppercase;letter-spacing:.1em}
.appnav .section{padding:8px 16px;font-family:var(--fm);font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--ash-1);margin-top:16px}
.appnav a{display:flex;align-items:center;gap:12px;padding:10px 24px;color:var(--ash-2);font-size:14px;text-decoration:none;border-left:2px solid transparent;cursor:pointer;transition:all .15s}
.appnav a:hover{background:var(--ink-2);color:var(--paper)}
.appnav a.active{border-left-color:var(--cyan-1);background:var(--ink-2);color:var(--paper)}
.appnav a .dot{width:6px;height:6px;border-radius:50%;background:var(--ash-1)}
.appnav a.active .dot{background:var(--cyan-1);box-shadow:0 0 0 3px rgba(34,211,238,.2)}
.appnav .back{margin-top:auto;padding:20px 24px;border-top:1px solid var(--ink-3);font-family:var(--fm);font-size:11px;color:var(--ash-1);text-transform:uppercase;letter-spacing:.1em}
.appnav .back:hover{color:var(--cyan-1)}

.apphdr{grid-area:hdr;background:var(--ink-1);border-bottom:1px solid var(--ink-3);padding:0 32px;display:flex;align-items:center;justify-content:space-between}
.apphdr .crumbs{font-family:var(--fm);font-size:11px;color:var(--ash-1);letter-spacing:.08em;text-transform:uppercase}
.apphdr .crumbs strong{color:var(--paper);font-weight:500}
.apphdr .stats-right{display:flex;gap:24px;align-items:center;font-family:var(--fm);font-size:11px;color:var(--ash-1)}
.apphdr .stats-right .pill{padding:6px 12px;background:var(--ink-2);border:1px solid var(--ink-3);border-radius:4px}
.apphdr .stats-right .pill strong{color:var(--cyan-1);font-weight:500}
.apphdr .live{color:var(--ok)}
.apphdr .live::before{content:'●';margin-right:6px;animation:pulse 2s infinite}

.appmain{grid-area:main;padding:24px 32px;overflow-y:auto;max-height:calc(100vh - 56px)}

/* ═══ DASHBOARDS ═══ */
.dash-title{font-weight:700;font-size:28px;letter-spacing:-.02em;color:var(--paper);margin-bottom:4px}
.dash-sub{font-size:14px;color:var(--ash-2);margin-bottom:24px}

.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
.kpi{background:var(--ink-1);border:1px solid var(--ink-3);padding:18px 20px}
.kpi .l{font-family:var(--fm);font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--ash-1);margin-bottom:8px}
.kpi .v{font-weight:800;font-size:28px;color:var(--paper);letter-spacing:-.02em}
.kpi .v em{color:var(--cyan-1);font-style:normal}
.kpi .d{font-family:var(--fm);font-size:10px;margin-top:4px;color:var(--ash-1)}
.kpi .d.up{color:var(--ok)}
.kpi .d.warn{color:var(--warm)}

.dash-grid{display:grid;grid-template-columns:1fr 380px;gap:16px;margin-bottom:24px}

/* Mapa */
.mapcard{background:var(--ink-1);border:1px solid var(--ink-3);padding:20px;min-height:480px;position:relative}
.mapcard h3{font-weight:600;font-size:16px;color:var(--paper);margin-bottom:4px}
.mapcard .hint{font-family:var(--fm);font-size:11px;color:var(--ash-1);margin-bottom:16px}
.mapcanvas{position:relative;height:400px;background:var(--ink-0);border:1px solid var(--ink-3);overflow:hidden}
.mapcanvas svg{width:100%;height:100%}

/* Alertas */
.panel{background:var(--ink-1);border:1px solid var(--ink-3);padding:20px}
.panel h3{font-weight:600;font-size:16px;color:var(--paper);margin-bottom:4px}
.panel .hint{font-family:var(--fm);font-size:11px;color:var(--ash-1);margin-bottom:16px}
.alert{padding:12px 14px;border-left:3px solid var(--ink-4);background:var(--ink-2);margin-bottom:8px;cursor:pointer;transition:border-color .2s}
.alert:hover{border-left-color:var(--cyan-1)}
.alert.sev-4{border-left-color:var(--hot)}
.alert.sev-3{border-left-color:var(--warm)}
.alert.sev-2{border-left-color:var(--cyan-2)}
.alert .when{font-family:var(--fm);font-size:10px;color:var(--ash-1);margin-bottom:4px;letter-spacing:.08em}
.alert .what{font-size:13px;color:var(--paper);font-weight:500;margin-bottom:3px}
.alert .who{font-family:var(--fm);font-size:11px;color:var(--ash-2)}

.half{display:grid;grid-template-columns:1fr 1fr;gap:16px}

/* Edificios list */
.edlist{display:grid;gap:8px}
.edrow{background:var(--ink-1);border:1px solid var(--ink-3);padding:16px 20px;display:grid;grid-template-columns:auto 1fr auto auto auto;gap:20px;align-items:center;cursor:pointer;transition:border-color .2s}
.edrow:hover{border-color:var(--cyan-3)}
.edrow .silh{width:40px;height:40px;display:flex;align-items:flex-end;justify-content:center}
.edrow .info strong{display:block;color:var(--paper);font-size:14px;font-weight:500;margin-bottom:2px}
.edrow .info span{font-family:var(--fm);font-size:11px;color:var(--ash-1);letter-spacing:.05em}
.edrow .stat{font-family:var(--fm);font-size:11px;text-align:right;color:var(--ash-1)}
.edrow .stat strong{display:block;color:var(--paper);font-size:14px;font-weight:500;font-family:var(--fs)}
.edrow .health{width:56px;height:6px;background:var(--ink-3);border-radius:3px;overflow:hidden;position:relative}
.edrow .health .bar{position:absolute;left:0;top:0;height:100%;background:var(--ok);transition:width .5s}
.edrow .badge{font-family:var(--fm);font-size:10px;padding:4px 8px;border:1px solid var(--ink-4);color:var(--ash-2);text-transform:uppercase;letter-spacing:.1em}
.edrow .badge.ok{border-color:rgba(34,197,94,.3);color:#86efac}
.edrow .badge.warn{border-color:rgba(245,158,11,.3);color:#fcd34d}
.edrow .badge.crit{border-color:rgba(239,68,68,.3);color:#fca5a5}

/* Waveform */
.wfcard{background:var(--ink-1);border:1px solid var(--ink-3);padding:20px}
.wfcard h4{font-weight:500;font-size:13px;color:var(--paper);margin-bottom:12px;font-family:var(--fm);text-transform:uppercase;letter-spacing:.1em}
.wfcard .ch{display:flex;align-items:center;gap:12px;margin-bottom:8px;padding:8px 0;border-bottom:1px solid var(--ink-3)}
.wfcard .ch:last-child{border-bottom:none}
.wfcard .ch .lbl{font-family:var(--fm);font-size:10px;color:var(--ash-1);width:32px;letter-spacing:.08em}
.wfcard .ch svg{flex:1;height:36px}

/* Drawer detalle */
.drawer{position:fixed;inset:0;background:rgba(10,10,11,.85);backdrop-filter:blur(8px);z-index:100;display:flex;justify-content:flex-end}
.drawer-panel{width:min(900px,95%);background:var(--ink-1);border-left:1px solid var(--ink-3);display:flex;flex-direction:column;overflow:hidden;animation:slideIn .3s ease-out}
@keyframes slideIn{from{transform:translateX(100%)}to{transform:translateX(0)}}
.drawer-hdr{padding:20px 32px;border-bottom:1px solid var(--ink-3);display:flex;justify-content:space-between;align-items:center}
.drawer-hdr h2{font-weight:700;font-size:22px;letter-spacing:-.015em;color:var(--paper)}
.drawer-hdr .code{font-family:var(--fm);font-size:11px;color:var(--cyan-2);letter-spacing:.08em;margin-top:4px}
.drawer-hdr button{color:var(--ash-2);font-size:20px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border:1px solid var(--ink-3)}
.drawer-hdr button:hover{color:var(--paper);border-color:var(--cyan-2)}
.drawer-body{flex:1;overflow-y:auto;padding:24px 32px;display:grid;grid-template-columns:260px 1fr;gap:24px}
.drawer-silh{background:var(--ink-0);border:1px solid var(--ink-3);padding:16px;display:flex;align-items:center;justify-content:center}
.drawer-silh svg{max-height:280px;width:auto}
.drawer-right{display:flex;flex-direction:column;gap:16px}
.drawer-meta{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--ink-3);border:1px solid var(--ink-3)}
.drawer-meta div{background:var(--ink-1);padding:14px}
.drawer-meta .l{font-family:var(--fm);font-size:10px;color:var(--ash-1);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.drawer-meta .v{font-weight:600;font-size:18px;color:var(--paper);letter-spacing:-.01em}
.drawer-meta .v em{font-style:normal;color:var(--cyan-1)}

.nodelist{background:var(--ink-1);border:1px solid var(--ink-3)}
.nodelist .row{padding:10px 16px;display:grid;grid-template-columns:auto 1fr auto auto;gap:12px;align-items:center;border-bottom:1px solid var(--ink-3);font-family:var(--fm);font-size:11px}
.nodelist .row:last-child{border-bottom:none}
.nodelist .row .d{width:8px;height:8px;border-radius:50%;background:var(--ok)}
.nodelist .row .d.warn{background:var(--warm)}
.nodelist .row .d.crit{background:var(--hot);animation:pulse 1s infinite}
.nodelist .row .ch{color:var(--paper)}
.nodelist .row .where{color:var(--ash-2)}
.nodelist .row .v{color:var(--cyan-1)}
.nodelist .row .s{color:var(--ash-1)}

@media(max-width:960px){
  .roles{grid-template-columns:1fr}
  .app{grid-template-columns:1fr;grid-template-areas:"hdr""main"}
  .appnav{display:none}
  .dash-grid{grid-template-columns:1fr}
  .kpis{grid-template-columns:repeat(2,1fr)}
  .edrow{grid-template-columns:1fr}
  .drawer-body{grid-template-columns:1fr}
  .drawer-meta{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

<!-- ═══════════ HOME ═══════════ -->
<div class="home" data-screen="home">
  <div class="home-hdr">
    <div class="logo-mini"><strong>MOVE</strong><span>idworld · red sísmica v0.1.0</span></div>
    <div class="home-meta">Alejandría Steam Labs · 30 nodos activos</div>
  </div>

  <div class="home-hero">
    <div class="home-kicker">Elegí tu rol para entrar al sistema</div>
    <h1 class="home-title">Cuatro edificios escuchados. <em>Tres lentes</em> para leerlos.</h1>
    <p class="home-sub">Protección Civil ve riesgo. El Sismólogo ve señal. El Ingeniero ve estructura. Mismos datos, distintos focos.</p>
  </div>

  <div class="roles">
    <button class="role-card" style="--cc:#22d3ee" onclick="enter('proteccion-civil')">
      <div class="ic">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2L3 6v5c0 4 3 7 7 7s7-3 7-7V6l-7-4z"/></svg>
      </div>
      <h3>Protección Civil</h3>
      <div class="subt">Operaciones · alertas</div>
      <p>Mapa operativo en tiempo real, alertas de eventos sísmicos, estado de la red, edificios críticos vigilados.</p>
      <ul>
        <li><span>Vista</span><strong>Municipio → edificio → nodo</strong></li>
        <li><span>Prioridad</span><strong>Alertas y latencia</strong></li>
        <li><span>SLA</span><strong>&lt;50 ms onda P</strong></li>
      </ul>
      <span class="enter">Entrar como PC →</span>
    </button>

    <button class="role-card" style="--cc:#a78bfa" onclick="enter('sismologo')">
      <div class="ic">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 10h3l2-6 2 12 2-10 2 8 2-4 2 4h3"/></svg>
      </div>
      <h3>Sismólogo MARN</h3>
      <div class="subt">Red sísmica · waveforms</div>
      <p>Streams sísmicos FDSN en vivo, detección de fases P/S, caracterización de eventos, acceso miniSEED y SeedLink.</p>
      <ul>
        <li><span>Vista</span><strong>Zona NTDS → fuente → estación</strong></li>
        <li><span>Prioridad</span><strong>Calidad de señal</strong></li>
        <li><span>Stack</span><strong>ObsPy · SeedLink · StationXML</strong></li>
      </ul>
      <span class="enter">Entrar como MARN →</span>
    </button>

    <button class="role-card" style="--cc:#fb7185" onclick="enter('estructural')">
      <div class="ic">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="2" width="12" height="16"/><line x1="4" y1="7" x2="16" y2="7"/><line x1="4" y1="12" x2="16" y2="12"/></svg>
      </div>
      <h3>Ingeniero Estructural</h3>
      <div class="subt">Salud edificio · modos propios</div>
      <p>Periodo fundamental, amortiguamiento, drift entre pisos, tendencias de fatiga. SHM continuo bajo ISO 16587.</p>
      <ul>
        <li><span>Vista</span><strong>Tipología → ocupación → unidad</strong></li>
        <li><span>Prioridad</span><strong>Tendencias modales</strong></li>
        <li><span>Norma</span><strong>ISO 16587 · NTDS 94</strong></li>
      </ul>
      <span class="enter">Entrar como Ing. →</span>
    </button>
  </div>
</div>

<!-- ═══════════ APP (uno por rol, JS muestra el correcto) ═══════════ -->
<div class="app hide" data-screen="app">
  <aside class="appnav">
    <div class="brand"><strong>MOVE</strong><span id="appRoleLabel">Protección Civil</span></div>
    <div class="section">Dashboard</div>
    <a class="active" data-view="overview"><span class="dot"></span> Vista general</a>
    <a data-view="edificios"><span class="dot"></span> Edificios</a>
    <a data-view="alertas"><span class="dot"></span> Alertas</a>
    <a data-view="red"><span class="dot"></span> Red y gateways</a>
    <div class="section">Datos</div>
    <a data-view="eventos"><span class="dot"></span> Eventos sísmicos</a>
    <a data-view="exportar"><span class="dot"></span> Exportar miniSEED</a>
    <div class="back" onclick="home()">← Cambiar rol</div>
  </aside>

  <header class="apphdr">
    <div class="crumbs">idworld / <strong id="crumbRole">Protección Civil</strong> / <strong id="crumbView">Vista general</strong></div>
    <div class="stats-right">
      <span class="live">red en vivo</span>
      <span class="pill">Nodos <strong id="hdrNodos">30</strong>/30</span>
      <span class="pill">Gateways <strong id="hdrGw">4</strong>/4</span>
      <span class="pill" id="hdrTime">--:--:--</span>
    </div>
  </header>

  <main class="appmain" id="appMain"></main>
</div>

<!-- ═══════════ DRAWER detalle edificio ═══════════ -->
<div class="drawer hide" id="drawer">
  <div class="drawer-panel">
    <div class="drawer-hdr">
      <div>
        <h2 id="dwName">Edificio</h2>
        <div class="code" id="dwCode">SV-SS-XXX-001</div>
      </div>
      <button onclick="closeDrawer()">×</button>
    </div>
    <div class="drawer-body" id="dwBody"></div>
  </div>
</div>

<script>
/* ═══════════════════════════════════════════
   DATA — 4 edificios reales + nodos simulados
   ═══════════════════════════════════════════ */
const EDIFICIOS = [
  {
    code:'SV-SS-TPR-001', nombre:'Torre Presidente', tipo:'tower',
    altura:100, pisos:20, anio:2018, sistema:'Concreto armado',
    ntds:'III · S2', lat:13.6985, lng:-89.2350,
    nodos:[
      {ch:'TPR01.00',loc:'Cimiento N',z:0},{ch:'TPR01.01',loc:'Cimiento S',z:0},
      {ch:'TPR01.02',loc:'Piso 5 N',z:25},{ch:'TPR01.03',loc:'Piso 5 S',z:25},
      {ch:'TPR01.04',loc:'Piso 12',z:60},{ch:'TPR01.05',loc:'Piso 18 N',z:90},
      {ch:'TPR01.06',loc:'Azotea N',z:100},{ch:'TPR01.07',loc:'Azotea S',z:100}
    ],
    periodo:2.1, amort:5.0, health:94
  },
  {
    code:'SV-SS-CAT-001', nombre:'Catedral Metropolitana', tipo:'temple',
    altura:50, pisos:3, anio:1999, sistema:'Concreto + acero',
    ntds:'II · S3', lat:13.6994, lng:-89.1905,
    nodos:[
      {ch:'CAT01.00',loc:'Cimiento central',z:0},{ch:'CAT01.01',loc:'Cim. torre N',z:0},
      {ch:'CAT01.02',loc:'Cim. torre S',z:0},{ch:'CAT01.03',loc:'Base cúpula',z:20},
      {ch:'CAT01.04',loc:'Cúpula media',z:35},{ch:'CAT01.05',loc:'Cúpula superior',z:45},
      {ch:'CAT01.06',loc:'Torre N top',z:50},{ch:'CAT01.07',loc:'Torre S top',z:50}
    ],
    periodo:0.8, amort:4.0, health:87
