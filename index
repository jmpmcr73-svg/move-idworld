/* ═══════════════════════════════════════════
   Silhouettes por tipología
   ═══════════════════════════════════════════ */
function silhouette(ed, size=40, showNodes=false){
  const h=size, w=ed.tipo==='tower'?h*0.4:h*1.6;
  const nodes=showNodes?ed.nodos.map(n=>{
    const y=h-(n.z/ed.altura)*(h-8)-4;
    return `<circle cx="${w/2}" cy="${y}" r="${showNodes===true?2.5:1.8}" fill="#22c55e"/>`;
  }).join(''):'';
  if(ed.tipo==='tower')
    return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><rect x="${w*0.3}" y="2" width="${w*0.4}" height="${h-2}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><rect x="${w*0.45}" y="0" width="${w*0.1}" height="3" fill="#0891b2"/>${nodes}</svg>`;
  if(ed.tipo==='temple')
    return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><rect x="${w*0.05}" y="${h*0.45}" width="${w*0.12}" height="${h*0.55}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><rect x="${w*0.83}" y="${h*0.45}" width="${w*0.12}" height="${h*0.55}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><rect x="${w*0.27}" y="${h*0.6}" width="${w*0.46}" height="${h*0.4}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><circle cx="${w*0.5}" cy="${h*0.55}" r="${h*0.18}" fill="none" stroke="#22d3ee" stroke-width="0.8"/>${nodes}</svg>`;
  if(ed.tipo==='heritage')
    return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><rect x="${w*0.05}" y="${h*0.4}" width="${w*0.9}" height="${h*0.6}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><polygon points="${w*0.42},${h*0.4} ${w*0.58},${h*0.4} ${w*0.5},${h*0.28}" fill="#0891b2"/>${nodes}</svg>`;
  return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><rect x="${w*0.1}" y="${h*0.4}" width="${w*0.8}" height="${h*0.6}" fill="none" stroke="#22d3ee" stroke-width="0.8"/><line x1="${w*0.2}" y1="${h*0.55}" x2="${w*0.2}" y2="${h*0.95}" stroke="#22d3ee" stroke-width="0.5"/><line x1="${w*0.4}" y1="${h*0.55}" x2="${w*0.4}" y2="${h*0.95}" stroke="#22d3ee" stroke-width="0.5"/><line x1="${w*0.6}" y1="${h*0.55}" x2="${w*0.6}" y2="${h*0.95}" stroke="#22d3ee" stroke-width="0.5"/><line x1="${w*0.8}" y1="${h*0.55}" x2="${w*0.8}" y2="${h*0.95}" stroke="#22d3ee" stroke-width="0.5"/>${nodes}</svg>`;
}

