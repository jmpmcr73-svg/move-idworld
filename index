function drawMap(){
  const c=document.getElementById('mapCanvas');
  if(!c)return;
  const latMin=13.690, latMax=13.705, lngMin=-89.24, lngMax=-89.185;
  const project=(lat,lng)=>{
    const x=((lng-lngMin)/(lngMax-lngMin))*100;
    const y=((latMax-lat)/(latMax-latMin))*100;
    return {x,y};
  };
  const pins=EDIFICIOS.map(ed=>{
    const p=project(ed.lat,ed.lng);
    const sev=ed.health>85?'#22c55e':ed.health>75?'#f59e0b':'#ef4444';
    return `
      <g style="cursor:pointer" onclick='openDrawer("${ed.code}")'>
        <circle cx="${p.x}%" cy="${p.y}%" r="18" fill="${sev}" opacity="0.15">
          <animate attributeName="r" values="14;22;14" dur="3s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.25;0;0.25" dur="3s" repeatCount="indefinite"/>
        </circle>
        <circle cx="${p.x}%" cy="${p.y}%" r="6" fill="${sev}" stroke="#0a0a0b" stroke-width="2"/>
        <text x="${p.x}%" y="${p.y}%" dy="-14" text-anchor="middle" fill="#f4f4f5" font-family="JetBrains Mono,monospace" font-size="10" font-weight="700">${ed.code.slice(-7,-4)}</text>
        <text x="${p.x}%" y="${p.y}%" dy="24" text-anchor="middle" fill="#a1a1aa" font-family="Archivo,sans-serif" font-size="10">${ed.nombre}</text>
      </g>`;
  }).join('');
  const mesh=[
    [EDIFICIOS[1],EDIFICIOS[2]],[EDIFICIOS[1],EDIFICIOS[3]],[EDIFICIOS[2],EDIFICIOS[3]],
    [EDIFICIOS[0],EDIFICIOS[1]],[EDIFICIOS[0],EDIFICIOS[2]]
  ].map(([a,b])=>{
    const pa=project(a.lat,a.lng),pb=project(b.lat,b.lng);
    return `<line x1="${pa.x}%" y1="${pa.y}%" x2="${pb.x}%" y2="${pb.y}%" stroke="#0891b2" stroke-width="1" opacity="0.4" stroke-dasharray="4 4"/>`;
  }).join('');
  c.innerHTML=`
    <svg viewBox="0 0 100 100" preserveAspectRatio="none" style="position:absolute;inset:0;width:100%;height:100%">
      <defs><pattern id="mg" width="5" height="5" patternUnits="userSpaceOnUse"><path d="M 5 0 L 0 0 0 5" fill="none" stroke="#27272a" stroke-width="0.2"/></pattern></defs>
      <rect width="100" height="100" fill="url(#mg)"/>
      <text x="4" y="96" fill="#52525b" font-family="JetBrains Mono" font-size="2.5">centro histórico SS · zona Rosa</text>
      <text x="96" y="96" text-anchor="end" fill="#52525b" font-family="JetBrains Mono" font-size="2.5">13.69°N · -89.21°W</text>
    </svg>
    <svg style="position:absolute;inset:0;width:100%;height:100%">${mesh}${pins}</svg>`;
}

/* ═══════════════════════════════════════════
   Waveforms animados
   ═══════════════════════════════════════════ */
const wfBuffers={z:[],n:[],e:[]};
let wfTick=0;
function addSample(){
  wfTick++;
  const spike=Math.random()<0.012?(Math.random()-0.5)*60:0;
  ['z','n','e'].forEach(ch=>{
    const noise=(Math.random()-0.5)*4;
    wfBuffers[ch].push(noise+(ch==='z'?spike:spike*0.6));
    if(wfBuffers[ch].length>120)wfBuffers[ch].shift();
  });
}
function drawWf(id,buf,color){
  const svg=document.getElementById(id);
  if(!svg)return;
  const w=svg.clientWidth||300, h=36;
  const path=buf.map((v,i)=>`${i===0?'M':'L'}${(i/120*w).toFixed(1)},${(h/2-v*0.7).toFixed(1)}`).join(' ');
  svg.innerHTML=`<line x1="0" y1="${h/2}" x2="${w}" y2="${h/2}" stroke="#27272a" stroke-width="0.5"/><path d="${path}" fill="none" stroke="${color}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`;
}
let wfTimer=null;
function startWaveforms(){
  if(wfTimer)return;
  for(let i=0;i<120;i++)addSample();
  wfTimer=setInterval(()=>{
    addSample();
    drawWf('wf-z',wfBuffers.z,'#22d3ee');
    drawWf('wf-n',wfBuffers.n,'#a78bfa');
    drawWf('wf-e',wfBuffers.e,'#fb7185');
  },80);
}

