nd:[{c:'TPR01.00',l:'Cimiento N',z:0},{c:'TPR01.01',l:'Cimiento S',z:0},{c:'TPR01.02',l:'Piso 5 N',z:25},{c:'TPR01.03',l:'Piso 5 S',z:25},{c:'TPR01.04',l:'Piso 12',z:60},{c:'TPR01.05',l:'Piso 18 N',z:90},{c:'TPR01.06',l:'Azotea N',z:100},{c:'TPR01.07',l:'Azotea S',z:100}],
