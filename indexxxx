let cRole='pc',cView='ov';

function enter(r){cRole=r;document.getElementById('home').classList.add('hide');document.getElementById('app').classList.remove('hide');document.getElementById('rL').textContent=RL[r].l;document.getElementById('cR').textContent=RL[r].l;cView='ov';document.querySelectorAll('.nv a').forEach(a=>a.classList.toggle('ac',a.dataset.v==='ov'));rn();}
