<meta name="viewport" content="width=device-width,initial-scale=1">
<title>MOVE · Sistema idworld</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&family=Fraunces:ital,wght@1,300&display=swap" rel="stylesheet">
<style>
:root{--ink0:#0a0a0b;--ink1:#121214;--ink2:#1a1a1d;--ink3:#27272a;--ink4:#3f3f46;--a1:#71717a;--a2:#a1a1aa;--a3:#d4d4d8;--pp:#f4f4f5;--c1:#22d3ee;--c2:#06b6d4;--c3:#0891b2;--ok:#22c55e;--wr:#f59e0b;--ht:#ef4444;--pu:#a78bfa;--co:#fb7185;--fs:'Archivo',system-ui,sans-serif;--fm:'JetBrains Mono',ui-monospace,monospace}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--ink0);color:var(--a3);font-family:var(--fs);line-height:1.5;-webkit-font-smoothing:antialiased}
button{font:inherit;color:inherit;background:none;border:none;cursor:pointer}
.hide{display:none!important}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes slideIn{from{transform:translateX(100%)}to{transform:translateX(0)}}

.home{min-height:100vh;padding:40px;background:radial-gradient(ellipse 1200px 800px at 50% 0%,rgba(8,145,178,.12),transparent 60%)}
.home-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:80px}
.logo{display:flex;align-items:baseline;gap:12px;font-family:var(--fm);font-size:11px;text-transform:uppercase;letter-spacing:.1em}
.logo strong{font-family:var(--fs);font-weight:900;font-size:22px;color:var(--pp);letter-spacing:-.02em}
.logo span{color:var(--a1)}
.hm{font-family:var(--fm);font-size:10px;color:var(--a1);letter-spacing:.1em;text-transform:uppercase}
.hm::before{content:'●';color:var(--ok);margin-right:6px;animation:pulse 2.5s infinite}
.hero{max-width:1200px;margin:0 auto 80px;text-align:center}
.kk{font-family:var(--fm);font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--c1);margin-bottom:20px}
.ht1{font-weight:800;font-size:clamp(36px,5vw,64px);letter-spacing:-.03em;line-height:1.05;color:var(--pp);margin-bottom:24px}
.ht1 em{font-style:normal;color:var(--c1)}
.hsub{font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:300;font-size:20px;color:var(--a2);max-width:600px;margin:0 auto}
.roles{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.rc{background:var(--ink1);border:1px solid var(--ink3);padding:40px 32px;transition:all .3s;cursor:pointer;position:relative;overflow:hidden;text-align:left}
.rc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--cc);transform:scaleY(0);transform-origin:top;transition:transform .3s}
.rc:hover{border-color:var(--cc);transform:translateY(-4px)}
.rc:hover::before{transform:scaleY(1)}
.rc .ic{width:48px;height:48px;border:1px solid var(--cc);display:flex;align-items:center;justify-content:center;margin-bottom:28px;color:var(--cc)}
.rc h3{font-weight:700;font-size:24px;letter-spacing:-.015em;color:var(--pp);margin-bottom:8px}
.rc .subt{font-family:var(--fm);font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--a1);margin-bottom:24px}
.rc p{font-size:15px;color:var(--a2);line-height:1.6;margin-bottom:28px}
.rc ul{list-style:none;font-family:var(--fm);font-size:11.5px;color:var(--a1);border-top:1px solid var(--ink3);padding-top:20px}
.rc li{padding:6px 0;display:flex;justify-content:space-between;gap:12px}
.rc li strong{color:var(--cc);font-weight:500}
.rc .en{margin-top:28px;font-family:var(--fm);font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--cc);padding:14px 20px;border:1px solid var(--cc);display:inline-block;transition:background .2s}
.rc:hover .en{background:var(--cc);color:var(--ink0)}

.app{min-height:100vh;display:grid;grid-template-rows:56px 1fr;grid-template-columns:240px 1fr;grid-template-areas:"nav hdr" "nav main"}
.nv{grid-area:nav;background:var(--ink1);border-right:1px solid var(--ink3);padding:20px 0;display:flex;flex-direction:column}
.nv .br{padding:0 24px 24px;border-bottom:1px solid var(--ink3);margin-bottom:20px}
.nv .br strong{font-weight:900;font-size:18px;color:var(--pp);letter-spacing:-.02em;display:block}
.nv .br span{font-family:var(--fm);font-size:10px;color:var(--a1);text-transform:uppercase;letter-spacing:.1em}
.nv .sc{padding:8px 16px;font-family:var(--fm);font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--a1);margin-top:16px}
.nv a{display:flex;align-items:center;gap:12px;padding:10px 24px;color:var(--a2);font-size:14px;text-decoration:none;border-left:2px solid transparent;cursor:pointer;transition:all .15s}
.nv a:hover{background:var(--ink2);color:var(--pp)}
.nv a.ac{border-left-color:var(--c1);background:var(--ink2);color:var(--pp)}
.nv a .d{width:6px;height:6px;border-radius:50%;background:var(--a1)}
.nv a.ac .d{background:var(--c1);box-shadow:0 0 0 3px rgba(34,211,238,.2)}
.nv .bk{margin-top:auto;padding:20px 24px;border-top:1px solid var(--ink3);font-family:var(--fm);font-size:11px;color:var(--a1);text-transform:uppercase;letter-spacing:.1em;cursor:pointer}
.nv .bk:hover{color:var(--c1)}
.hd{grid-area:hdr;background:var(--ink1);border-bottom:1px solid var(--ink3);padding:0 32px;display:flex;align-items:center;justify-content:space-between}
.hd .cr{font-family:var(--fm);font-size:11px;color:var(--a1);letter-spacing:.08em;text-transform:uppercase}
.hd .cr strong{color:var(--pp);font-weight:500}
.hd .rg{display:flex;gap:24px;align-items:center;font-family:var(--fm);font-size:11px;color:var(--a1)}
.hd .pl{padding:6px 12px;background:var(--ink2);border:1px solid var(--ink3);border-radius:4px}
.hd .pl strong{color:var(--c1);font-weight:500}
.hd .lv{color:var(--ok)}
.hd .lv::before{content:'●';margin-right:6px;animation:pulse 2s infinite}
.mn{grid-area:main;padding:24px 32px;overflow-y:auto;max-height:calc(100vh - 56px)}

.dt{font-weight:700;font-size:28px;letter-spacing:-.02em;color:var(--pp);margin-bottom:4px}
.ds{font-size:14px;color:var(--a2);margin-bottom:24px}
.kp{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
.ki{background:var(--ink1);border:1px solid var(--ink3);padding:18px 20px}
.ki .l{font-family:var(--fm);font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--a1);margin-bottom:8px}
.ki .v{font-weight:800;font-size:28px;color:var(--pp);letter-spacing:-.02em}
.ki .v em{color:var(--c1);font-style:normal}
.ki .dd{font-family:var(--fm);font-size:10px;margin-top:4px;color:var(--a1)}
.ki .dd.up{color:var(--ok)}
.ki .dd.wr{color:var(--wr)}
.dg{display:grid;grid-template-columns:1fr 380px;gap:16px;margin-bottom:24px}
.mp{background:var(--ink1);border:1px solid var(--ink3);padding:20px;min-height:480px;position:relative}
.mp h3{font-weight:600;font-size:16px;color:var(--pp);margin-bottom:4px}
.hn{font-family:var(--fm);font-size:11px;color:var(--a1);margin-bottom:16px}
.mc{position:relative;height:400px;background:var(--ink0);border:1px solid var(--ink3);overflow:hidden}
.pn{background:var(--ink1);border:1px solid var(--ink3);padding:20px}
.pn h3{font-weight:600;font-size:16px;color:var(--pp);margin-bottom:4px}
.al{padding:12px 14px;border-left:3px solid var(--ink4);background:var(--ink2);margin-bottom:8px;cursor:pointer;transition:border-color .2s}
.al:hover{border-left-color:var(--c1)}
.al.s4{border-left-color:var(--ht)}
.al.s3{border-left-color:var(--wr)}
.al.s2{border-left-color:var(--c2)}
.al .wn{font-family:var(--fm);font-size:10px;color:var(--a1);margin-bottom:4px;letter-spacing:.08em}
.al .wt{font-size:13px;color:var(--pp);font-weight:500;margin-bottom:3px}
.al .wo{font-family:var(--fm);font-size:11px;color:var(--a2)}
.hf{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.el{display:grid;gap:8px}
.er{background:var(--ink1);border:1px solid var(--ink3);padding:16px 20px;display:grid;grid-template-columns:auto 1fr auto auto auto;gap:20px;align-items:center;cursor:pointer;transition:border-color .2s}
.er:hover{border-color:var(--c3)}
.er .sl{width:40px;height:40px;display:flex;align-items:flex-end;justify-content:center}
.er .ii strong{display:block;color:var(--pp);font-size:14px;font-weight:500;margin-bottom:2px}
.er .ii span{font-family:var(--fm);font-size:11px;color:var(--a1);letter-spacing:.05em}
.er .st{font-family:var(--fm);font-size:11px;text-align:right;color:var(--a1)}
.er .st strong{display:block;color:var(--pp);font-size:14px;font-weight:500;font-family:var(--fs)}
.er .he{width:56px;height:6px;background:var(--ink3);border-radius:3px;overflow:hidden;position:relative}
.er .he .bar{position:absolute;left:0;top:0;height:100%;transition:width .5s}
.er .bd{font-family:var(--fm);font-size:10px;padding:4px 8px;border:1px solid var(--ink4);color:var(--a2);text-transform:uppercase;letter-spacing:.1em}
.er .bd.ok{border-color:rgba(34,197,94,.3);color:#86efac}
.er .bd.wr{border-color:rgba(245,158,11,.3);color:#fcd34d}
.er .bd.cr{border-color:rgba(239,68,68,.3);color:#fca5a5}
.wf{background:var(--ink1);border:1px solid var(--ink3);padding:20px}
.wf h4{font-weight:500;font-size:13px;color:var(--pp);margin-bottom:12px;font-family:var(--fm);text-transform:uppercase;letter-spacing:.1em}
.wf .ch{display:flex;align-items:center;gap:12px;margin-bottom:8px;padding:8px 0;border-bottom:1px solid var(--ink3)}
.wf .ch:last-child{border-bottom:none}
.wf .ch .lb{font-family:var(--fm);font-size:10px;color:var(--a1);width:32px;letter-spacing:.08em}
.wf .ch svg{flex:1;height:36px}
.dr{position:fixed;inset:0;background:rgba(10,10,11,.85);backdrop-filter:blur(8px);z-index:100;display:flex;justify-content:flex-end}
.dp{width:min(900px,95%);background:var(--ink1);border-left:1px solid var(--ink3);display:flex;flex-direction:column;overflow:hidden;animation:slideIn .3s ease-out}
.dh{padding:20px 32px;border-bottom:1px solid var(--ink3);display:flex;justify-content:space-between;align-items:center}
.dh h2{font-weight:700;font-size:22px;letter-spacing:-.015em;color:var(--pp)}
.dh .cd{font-family:var(--fm);font-size:11px;color:var(--c2);letter-spacing:.08em;margin-top:4px}
.dh button{color:var(--a2);font-size:20px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border:1px solid var(--ink3)}
.dh button:hover{color:var(--pp);border-color:var(--c2)}
.db{flex:1;overflow-y:auto;padding:24px 32px;display:grid;grid-template-columns:260px 1fr;gap:24px}
.dsl{background:var(--ink0);border:1px solid var(--ink3);padding:16px;display:flex;align-items:center;justify-content:center}
.dr2{display:flex;flex-direction:column;gap:16px}
.dm{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--ink3);border:1px solid var(--ink3)}
.dm div{background:var(--ink1);padding:14px}
.dm .l{font-family:var(--fm);font-size:10px;color:var(--a1);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.dm .v{font-weight:600;font-size:18px;color:var(--pp);letter-spacing:-.01em}
.dm .v em{font-style:normal;color:var(--c1)}
.nl{background:var(--ink1);border:1px solid var(--ink3)}
.nl .r{padding:10px 16px;display:grid;grid-template-columns:auto 1fr auto auto;gap:12px;align-items:center;border-bottom:1px solid var(--ink3);font-family:var(--fm);font-size:11px}
.nl .r:last-child{border-bottom:none}
.nl .r .dt2{width:8px;height:8px;border-radius:50%;background:var(--ok)}
.nl .r .dt2.wr{background:var(--wr)}
.nl .r .dt2.cr{background:var(--ht);animation:pulse 1s infinite}
.nl .r .c{color:var(--pp)}
.nl .r .w{color:var(--a2)}
.nl .r .v{color:var(--c1)}
.nl .r .s{color:var(--a1)}
@media(max-width:960px){.roles{grid-template-columns:1fr}.app{grid-template-columns:1fr;grid-template-areas:"hdr" "main"}.nv{display:none}.dg{grid-template-columns:1fr}.kp{grid-template-columns:repeat(2,1fr)}.db{grid-template-columns:1fr}.dm{grid-template-columns:1fr 1fr}}
</style>
</head>
